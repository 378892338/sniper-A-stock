*.parquet  *.pkl  *.pkl.gz
*.bak  *.log  *.log.*
*.swp  *.tmp
data/raw/_cache/
data/local/*.db  data/local/*.db-*  data/local/*.corrupted
test_recovery.db
_missing_syms.json
.l2_cache/
logs/
