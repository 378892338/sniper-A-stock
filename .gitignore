AGENTS.md
CLAUDE.md
CLAUDE.md.*
.ai/

# ── 凭证 / 启动脚本（含明文 token，禁用） ──
*.bat
scripts/run_daily.bat

# ── 历史备份目录（含 1.7GB SQLite 备份） ──
data/sources/backup/

# ── outputs/reports: 只跟踪日报 PDF，其余运行产物全部排除 ──
outputs/reports/*.log
outputs/reports/*.log.*
