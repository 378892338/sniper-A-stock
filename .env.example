# 凭证（请填真实值，不要 commit 本文件）
JQDATA_USERNAME=
JQDATA_PASSWORD=
TUSHARE_TOKEN=

# 数据仓根（必填，代码从这里读所有运行时数据）
# 默认：D:\projects\quant-data
# 迁移说明：所有 db / parquet / log / json / pkl 都在这个目录下
QUANT_DATA_ROOT=D:\projects\quant-data

# meta.db 路径（可选，默认在数据仓 local/ 下）
# 留空则使用默认：D:\projects\quant-data\local\meta.db
META_DB_PATH=
